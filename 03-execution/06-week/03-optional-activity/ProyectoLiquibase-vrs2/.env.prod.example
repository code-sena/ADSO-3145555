# ============================================================
#  Variables de entorno — PRODUCCIÓN
#
#  1. Copia este archivo: cp .env.prod.example .env.prod
#  2. Rellena los valores reales con los datos de tu servidor
#  3. NUNCA subas .env.prod a Git (ya está en .gitignore)
# ============================================================

# Host del servidor de base de datos (IP o dominio)
# Ejemplos:
#   bd.miempresa.com
#   192.168.1.100
#   zoo-db.render.com
PROD_DB_HOST=TU_HOST_AQUI

# Puerto (PostgreSQL usa 5432 por defecto)
PROD_DB_PORT=5432

# Nombre de la base de datos en el servidor
PROD_DB_NAME=zoologico_db

# Usuario con permisos de escritura (CREATE TABLE, INSERT, etc.)
PROD_DB_USER=TU_USUARIO_AQUI

# Contraseña del usuario
PROD_DB_PASSWORD=TU_PASSWORD_AQUI
